{
    "name": "react-docs-ui",
    "version": "0.6.12",
    "type": "module",
    "description": "React documentation site UI components — navigation, sidebar, search, code highlight, MDX rendering and theming to help you build docs fast.",
    "homepage": "https://shenjianZ.github.io/react-docs-ui",
    "keywords": [
        "react",
        "docs",
        "documentation",
        "ui",
        "component-library",
        "react-components",
        "mdx",
        "markdown",
        "documentation-site",
        "typescript"
    ],
    "module": "dist/react-docs-ui.es.js",
    "types": "dist/types/index.d.ts",
    "files": [
        "dist",
        "README.md",
        "package.json"
    ],
    "exports": {
        ".": {
            "types": "./dist/types/index.d.ts",
            "import": "./dist/react-docs-ui.es.js"
        },
        "./docs-app": {
            "types": "./dist/types/docs-app.d.ts",
            "import": "./dist/docs-app.es.js"
        },
        "./style.css": "./dist/react-docs-ui.css"
    },
    "scripts": {
        "dev": "vite",
        "build": "tsc -b && vite build",
        "build:lib": "tsc -p tsconfig.lib.json && vite build --config vite.config.lib.ts",
        "build:search": "node scripts/generate-search-index.mjs",
        "preview": "vite preview",
        "lint": "eslint .",
        "prepublishOnly": "npm run build:lib",
        "pdf:server": "tsx scripts/pdf-server.ts",
        "pdf:generate": "tsx scripts/generate-pdf-cli.ts"
    },
    "dependencies": {
        "@mdx-js/loader": "^3.0.0",
        "@mdx-js/react": "^3.0.0",
        "@radix-ui/react-collapsible": "^1.1.11",
        "@radix-ui/react-context-menu": "^2.2.15",
        "@radix-ui/react-dialog": "^1.1.14",
        "@radix-ui/react-dropdown-menu": "^2.1.15",
        "@radix-ui/react-scroll-area": "^1.2.9",
        "@radix-ui/react-slot": "^1.2.3",
        "@radix-ui/react-toast": "^1.2.15",
        "@radix-ui/react-tooltip": "^1.2.7",
        "@shikijs/transformers": "^4.0.1",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "cmdk": "^1.1.1",
        "docx": "^9.6.0",
        "file-saver": "^2.0.5",
        "flexsearch": "^0.8.212",
        "gray-matter": "^4.0.3",
        "html-to-image": "^1.11.13",
        "js-yaml": "^4.1.0",
        "jspdf": "^4.2.0",
        "jszip": "^3.10.1",
        "katex": "^0.16.11",
        "katex-physics": "^1.0.2",
        "lucide-react": "^0.539.0",
        "mdast": "^2.3.2",
        "next-themes": "^0.4.6",
        "react-markdown": "^10.1.0",
        "rehype-autolink-headings": "^7.1.0",
        "rehype-katex": "^7.0.1",
        "rehype-raw": "^7.0.0",
        "rehype-slug": "^6.0.0",
        "remark-gfm": "^4.0.1",
        "remark-math": "^6.0.0",
        "remark-parse": "^11.0.0",
        "remark-rehype": "^11.1.2",
        "shiki": "^4.0.1",
        "tailwind-merge": "^3.3.1",
        "turndown": "^7.2.2",
        "unified": "^11.0.5",
        "unist-util-visit": "^5.1.0"
    },
    "devDependencies": {
        "@eslint/js": "^9.32.0",
        "@tailwindcss/vite": "^4.1.11",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/file-saver": "^2.0.7",
        "@types/hast": "^3.0.4",
        "@types/node": "^24.2.1",
        "@types/react": "^19.1.9",
        "@types/react-dom": "^19.1.7",
        "@types/turndown": "^5.0.6",
        "@vitejs/plugin-react": "^4.7.0",
        "buffer": "^6.0.3",
        "cors": "^2.8.6",
        "eslint": "^9.32.0",
        "eslint-plugin-react-hooks": "^5.2.0",
        "eslint-plugin-react-refresh": "^0.4.20",
        "express": "^5.2.1",
        "glob": "^11.0.3",
        "globals": "^16.3.0",
        "puppeteer": "^24.38.0",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "react-router-dom": "^7.8.0",
        "tailwindcss": "^4.1.11",
        "tsx": "^4.21.0",
        "tw-animate-css": "^1.3.6",
        "typescript": "~5.8.3",
        "typescript-eslint": "^8.39.0",
        "vite": "^7.1.0",
        "vite-plugin-dts": "^4.5.4",
        "vite-plugin-node-polyfills": "^0.24.0"
    },
    "peerDependencies": {
        "react": ">=18",
        "react-dom": ">=18",
        "react-router-dom": "^7"
    },
    "engines": {
        "node": ">=18"
    },
    "publishConfig": {
        "access": "public"
    },
    "packageManager": "pnpm@10.17.1+sha512.17c560fca4867ae9473a3899ad84a88334914f379be46d455cbf92e5cf4b39d34985d452d2583baf19967fa76cb5c17bc9e245529d0b98745721aa7200ecaf7a"
}
